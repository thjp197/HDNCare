# Frontend (Client)
# Public API base URL for Vite client
VITE_API_URL=http://localhost:4000
# Backward-compatible alias used in current codebase
VITE_BACKEND_URL=http://localhost:4000

# AR filter entry served by Client static public folder
VITE_AR_URL=/filter/index.html

# Optional plain alias if you use non-Vite tooling
API_URL=http://localhost:4000

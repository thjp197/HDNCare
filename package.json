{
  "name": "hdncare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:admin": "npm --prefix admin run dev -- --host 0.0.0.0 --port 5174",
    "dev:filter": "node -e \"console.log('AR Filter is served by Client at /filter/index.html')\"",
    "dev:backend": "npm --prefix backend run start",
    "dev": "concurrently -n \"WEB,ADMIN,FILTER,BACKEND\" -c \"cyan,blue,magenta,green\" \"npm run dev:web\" \"npm run dev:admin\" \"npm run dev:filter\" \"npm run dev:backend\"",
    "build:web": "vite build --outDir dist/web",
    "build:admin": "npm --prefix admin run build -- --outDir ../dist/admin",
    "build": "npm run build:web && npm run build:admin",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "axios": "^1.13.6",
    "framer-motion": "^12.27.4",
    "lucide": "^1.7.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.0",
    "react-toastify": "^11.0.5",
    "swiper": "^12.1.3",
    "vnpay": "^2.4.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
